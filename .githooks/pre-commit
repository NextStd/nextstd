#!/bin/sh
set -e

# Ensure the script runs from the repository root
cd "$(git rev-parse --show-toplevel)"

echo "Formatting Rust code..."
cargo fmt --all

# Get staged Rust files and re-stage them so the formatting is included in the commit
RUST_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
if [ -n "$RUST_FILES" ]; then
  echo "$RUST_FILES" | tr '\n' '\0' | xargs -0 -r git add
fi

# Get staged Markdown files
MD_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' || true)

if [ -n "$MD_FILES" ]; then
  echo "Fixing markdown..."
  # Run rumdl and safely handle filenames with spaces
  echo "$MD_FILES" | tr '\n' '\0' | xargs -0 -r rumdl check --fix

  # Only re-stage the markdown files we just fixed
  echo "$MD_FILES" | tr '\n' '\0' | xargs -0 -r git add
fi

exit 0
